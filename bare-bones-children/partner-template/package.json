{
  "name": "partner-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "VITE_DEPLOYMENT_TARGET=local vite",
    "dev:staging": "VITE_DEPLOYMENT_TARGET=staging VITE_API_URL=https://api.bear-bones.xyz vite",
    "dev:live": "VITE_DEPLOYMENT_TARGET=live VITE_API_URL=https://api.bear-bones.xyz vite",
    "build": "tsc && vite build",
    "build:local": "VITE_DEPLOYMENT_TARGET=local tsc && VITE_DEPLOYMENT_TARGET=local vite build",
    "build:staging": "VITE_DEPLOYMENT_TARGET=staging tsc && VITE_DEPLOYMENT_TARGET=staging VITE_API_URL=https://api.bear-bones.xyz vite build",
    "build:live": "VITE_DEPLOYMENT_TARGET=live tsc && VITE_DEPLOYMENT_TARGET=live VITE_API_URL=https://api.bear-bones.xyz vite build",
    "deploy:github-pages": "bash scripts/deploy-github-pages.sh",
    "deploy:github-pages:local": "bash scripts/deploy-github-pages.sh --local",
    "deploy:github-pages:staging": "bash scripts/deploy-github-pages.sh --staging",
    "deploy:github-pages:live": "bash scripts/deploy-github-pages.sh --live",
    "extract-error-selectors": "node scripts/generate-error-selectors.mjs --inputFolders=src/abis --outputMap=src/utils/abiUtils.ts",
    "extract-function-selectors": "node scripts/generate-function-selectors.mjs --inputFolders=src/abis --outputMap=src/utils/functionSelectorMap.ts",
    "arweave:estimate": "node scripts/estimate-deploy-arweave.mjs",
    "arweave:fund-bundlr": "node scripts/fund-bundlr.mjs",
    "arweave:deploy": "node scripts/deploy-arweave.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:demo": "PLAYWRIGHT_DEMO=1 playwright test --headed",
    "test:e2e:codegen": "playwright codegen http://localhost:5173",
    "test:e2e:index": "playwright test page-element-index"
  },
  "dependencies": {
    "@reown/walletkit": "^1.4.1",
    "@tanstack/react-virtual": "^3.13.13",
    "@walletconnect/core": "^2.23.3",
    "@walletconnect/sign-client": "^2.23.1",
    "@walletconnect/utils": "^2.23.1",
    "buffer": "^6.0.3",
    "ethers": "^5.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.2",
    "tslib": "^2.8.1"
  },
  "resolutions": {
    "axios": "^1.8.2",
    "form-data": "^4.0.4",
    "h3": "^1.15.5"
  },
  "devDependencies": {
    "@bundlr-network/client": "^0.11.17",
    "@playwright/test": "^1.59.1",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "fs-extra": "^11.3.3",
    "mime": "^4.1.0",
    "sass": "^1.95.0",
    "typescript": "^5.0.2",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "engines": {
    "node": ">=22"
  }
}
