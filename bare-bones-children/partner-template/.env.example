VITE_APP_NAME=Bear Bones Wallet
VITE_DEPLOYMENT_TARGET=local
VITE_API_BASE_URL=http://localhost:3001
VITE_API_QUOTE_URL_BASE=http://localhost:8181

BUNDLR_PRIVATE_KEY=0xYOUR_DEPLOY_KEY
BUNDLR_NODE=https://node1.bundlr.network
BUNDLR_CHAIN=matic

# Legal-doc variable injection. These get substituted into the Privacy
# Policy (and future ToS) at build time. Anything unset falls back to a
# bracketed placeholder ("[Your Company, Inc.]") so a dev build renders
# but is obviously not production-configured. See src/config/legal.ts.
VITE_LEGAL_COMPANY_NAME=Your Company, Inc.
VITE_LEGAL_SERVICE_NAME=Your Service Name
VITE_LEGAL_WEBSITE_URL=https://example.com
VITE_LEGAL_COMPANY_ADDRESS=123 Main St, Cheyenne, WY 82001
VITE_LEGAL_PRIVACY_CONTACT_EMAIL=privacy@example.com
VITE_LEGAL_EFFECTIVE_DATE=May 24, 2026
VITE_LEGAL_LAST_UPDATED_DATE=May 24, 2026